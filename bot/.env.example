# Discord Developer Portal -> General Information -> Application ID
DISCORD_CLIENT_ID=your_client_id_here

# Developer Portal -> Bot -> Token
DISCORD_BOT_TOKEN=your_bot_token_here

# Optional: comma-separated test guild IDs — cleared on deploy so global commands don't duplicate
# DISCORD_GUILD_IDS=1358552411718942913,1088790880573476964

# HTTP port (Fly/Railway set PORT automatically)
PORT=8080

# Discord @mention username for the bot (no spaces)
BOT_USERNAME=tilt-battle-royale

# Premium Apps SKUs (Discord Developer Portal → Monetization)
SUPPORTER_SKU_ID=1524938929273311302
TRAIL_PASS_SKU_ID=1524975586601340978

# Comma-separated Discord user IDs that may host all eras without Trail Pass
TRAIL_PASS_BYPASS_USER_IDS=1153034319271559328

# Optional — who may use /royale bot_players for solo testing (defaults to bypass list)
# SOLO_TEST_USER_IDS=1153034319271559328

# Optional — Discord invite link for /support (e.g. https://discord.gg/...)
# SUPPORT_SERVER_URL=

# Optional — GitHub issues or feedback form URL
# FEEDBACK_URL=

# Optional — Ko-fi tip jar link for /support donate (DM)
# KOFI_URL=https://ko-fi.com/jmenichole0

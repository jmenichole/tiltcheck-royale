# Tilt Battle Royale Bot - Environment Variables
# Copy this file to .env and fill in your values

# Discord Developer Portal -> General Information -> Application ID
DISCORD_CLIENT_ID=your_client_id_here

# Developer Portal -> OAuth2 -> Client Secret (for Activity auth backend)
DISCORD_CLIENT_SECRET=your_client_secret_here

# Developer Portal -> Bot -> Token
DISCORD_BOT_TOKEN=your_bot_token_here

# Right-click your server -> Copy Server ID (guild-scoped slash commands)
DISCORD_GUILD_ID=your_guild_id_here

# HTTP + WebSocket port (use PORT on Railway/Render; WS_PORT still works locally)
PORT=8080

# Public WebSocket URL for the static frontend (wss://your-bot-host in production)
WS_PUBLIC_URL=ws://localhost:8080

# Static Activity URL where the CRT spectator UI is hosted
ACTIVITY_URL=https://tiltroyale.netlify.app

# Discord @mention username for the bot (no spaces; change in Portal if auto-rename fails)
BOT_USERNAME=tilt-battle-royale
